{
  "manifest_version": 3,
  "name": "__MSG_ext_name__",
  "short_name": "WireGuardExt",
  "version": "0.2.2",
  "description": "__MSG_ext_description__",
  "default_locale": "en",
  "homepage_url": "https://github.com/yoprogramo/wireguardext",
  "author": "yoprogramo",
  "minimum_chrome_version": "116",

  "permissions": [
    "proxy",
    "storage",
    "nativeMessaging"
  ],
  "host_permissions": [],

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "WireGuardExt",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
